{
  "expo": {
    "name": "Xpress Vet",
    "slug": "xpress-vet",
    "version": "1.0.0",
    "scheme": "xpressvet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": ["ios", "android", "web"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xpressvet.marketplace"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.xpressvet.marketplace",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "title": "Xpress Vet — Nigeria's Pet Care Marketplace",
      "description": "Find trusted vets, kennels, and pet shops near you across Nigeria.",
      "favicon": "./assets/icon.png"
    }
  }
}